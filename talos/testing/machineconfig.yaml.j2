apiVersion: v1alpha1
kind: ResolverConfig
nameservers:
    - address: 172.22.0.1
searchDomains:
  domains:
    - zynthovian.xyz
---
apiVersion: v1alpha1
kind: WatchdogTimerConfig
device: /dev/watchdog0
timeout: 5m